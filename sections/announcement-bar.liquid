{%- comment -%}
  File: sections/custom-announcement-bar.liquid
  Description: Perfect 3-column desktop layout and toggleable mobile drawer.
{%- endcomment -%}

<section class="custom-announcement-bar" id="AnnouncementBar">
  
  <div class="announcement-mobile-header">
    <button class="mobile-toggle" id="MobileToggle" aria-label="Toggle Menu">
      <svg class="icon-hamburger" width="20" height="14" viewBox="0 0 20 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1H19M1 7H19M1 13H19" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <svg class="icon-close" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none;">
        <path d="M15 1L1 15M1 1L15 15" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    
    <div class="announcement-brand">
      <h2>{{ section.settings.brand_text }}</h2>
    </div>
  </div>

  <div class="announcement-desktop-bar">
    <div class="announcement-col col-left">
      <div class="announcement-brand">
        <h2>{{ section.settings.brand_text }}</h2>
      </div>
    </div>
    
    <div class="announcement-col col-center">
      <span class="desktop-msg">{{ section.settings.message_text }}</span>
    </div>

    <div class="announcement-col col-right">
      {% if section.settings.btn_text != blank %}
        <a href="{{ section.settings.btn_link | default: '#' }}" class="announcement-btn">
          <span class="btn-text">{{ section.settings.btn_text }}</span>
          <svg class="arrow" width="24" height="12" viewBox="0 0 24 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 1L23 6M23 6L18 11M23 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>

  <div class="announcement-mobile-drawer" id="GiftDrawer">
    <p class="drawer-msg">{{ section.settings.message_text }}</p>
    {% if section.settings.btn_text != blank %}
      <a href="{{ section.settings.btn_link | default: '#' }}" class="announcement-btn">
        <span class="btn-text">{{ section.settings.btn_text }}</span>
        <svg class="arrow" width="24" height="12" viewBox="0 0 24 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 1L23 6M23 6L18 11M23 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {% endif %}
  </div>

</section>

<style>
  .custom-announcement-bar {
    width: 1,440px;
height: 64px;
    background-color: #f7f7f7;
    font-family: "Jost", "Futura", sans-serif;
    border-bottom: 1px solid #eaeaea;
    position: relative;
    z-index: 1001;
  }

  /* --- DESKTOP VIEW --- */
  .announcement-desktop-bar {
    display: flex;
    align-items: center;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
    min-height: 64px;
  }
  
  /* Hide mobile elements on desktop */
  .announcement-mobile-header, 
  .announcement-mobile-drawer { 
    display: none !important; 
  }

  .announcement-col { flex: 1; display: flex; align-items: center; }
  .col-left { justify-content: flex-start; }
  .col-center { justify-content: center; }
  .col-right { justify-content: flex-end; }

  .announcement-brand h2 {
    margin: 0; font-size: 25px; font-weight: 600; letter-spacing: 3.5px; text-transform: uppercase; color: #000000;
  }

  .desktop-msg { font-size: 16px; color: #000000; white-space: nowrap; }

  /* --- BUTTON & ANIMATION --- */
  .announcement-btn {
    position: relative; width:
207px; display: inline-flex; align-items: center; justify-content: center;
    background-color: #fdff00; color: #000; height:44px;
    text-decoration: none; font-weight: 500; font-size: 13px; letter-spacing: 1.5px;
    text-transform: uppercase; overflow: hidden; z-index: 1; border: none;
  }
  .announcement-btn::before {
    content: ""; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
    background-color: #000; transition: left 0.4s ease; z-index: -1;
  }
  .btn-text, .announcement-btn .arrow { position: relative; z-index: 2; transition: color 0.3s ease; }
  .announcement-btn .arrow { margin-left: 20px; }
  
  .announcement-btn:hover::before { left: 0; }
  .announcement-btn:hover .btn-text, .announcement-btn:hover .arrow { color: #fff; }
  .announcement-btn:hover .arrow { transform: translateX(5px); }

  /* --- MOBILE VIEW --- */
  @media (max-width: 850px) {
    /* Hide desktop elements on mobile */
    .announcement-desktop-bar { display: none !important; }
    
    .announcement-mobile-header {
      display: flex !important; align-items: center; justify-content: center;
      padding: 15px 20px; background-color: #f7f7f7; position: relative; min-height: 60px;
    }

    .mobile-toggle {
      position: absolute; left: 20px; background: none; border: none; cursor: pointer; padding: 10px;
      display: flex; align-items: center; justify-content: center;
    }

    .announcement-brand h2 { font-size: 18px; letter-spacing: 2px; }

    /* Open/Close Drawer Logic */
    .menu-open .announcement-mobile-drawer {
      display: flex !important;
      flex-direction: column; align-items: center;
      padding: 30px 20px; gap: 20px; border-top: 1px solid #eaeaea; background-color: #f7f7f7;
    }
    
    .drawer-msg { font-size: 14px; text-align: center; margin: 0; color: #000; }
    .announcement-mobile-drawer .announcement-btn { width: 100%; max-width: 300px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('MobileToggle');
    const bar = document.getElementById('AnnouncementBar');
    const hamburger = document.querySelector('.icon-hamburger');
    const closeIcon = document.querySelector('.icon-close');

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = bar.classList.toggle('menu-open');
        
        if (isOpen) {
          hamburger.style.display = 'none';
          closeIcon.style.display = 'block';
        } else {
          hamburger.style.display = 'block';
          closeIcon.style.display = 'none';
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Custom Announcement Bar",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand Name", "default": "TISSO VISON" },
    { "type": "text", "id": "message_text", "label": "Message", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Custom Announcement Bar" }]
}
{% endschema %}